# finance-pipeline-rag — environment template
# Copy this file to `.env` and fill in your own keys. NEVER commit `.env` (it's in .gitignore).
#
# Required for embedding + reranking (Voyage AI)
# Sign up at https://www.voyageai.com to get a key. Free tier is enough for a small corpus.
VOYAGE_API_KEY=

# Required for generation (Claude API). Get a key at https://console.anthropic.com.
# Note: if you have Claude Pro/Max, that subscription does NOT give API access — you need a separate API key.
ANTHROPIC_API_KEY=

# Optional — model overrides (defaults are set in code per plans/DECISIONS.md)
# ANTHROPIC_MODEL_DEV=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_EVAL=claude-sonnet-4-6
# VOYAGE_EMBED_MODEL=voyage-3-large
# VOYAGE_RERANK_MODEL=rerank-2

# Optional — Ollama judge LLM host (default is http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
