# Python virtual environment — local library box, never commit
venv/
.venv/
env/

# Python auto-generated bytecode + caches — rebuilt on every run
__pycache__/
*.pyc
*.pyo

# Secrets — API keys for Voyage + Anthropic + anything else
# NEVER commit. If you accidentally commit a .env, rotate the keys immediately.
.env
.env.local
.env.*.local

# Vector store local persistence (Chroma) — rebuilt by the embedding pipeline
chroma_db/
.chroma/

# Jupyter notebook auto-saves (only created if you open notebooks)
.ipynb_checkpoints/

# Test + coverage artifacts (regenerated each test run)
.pytest_cache/
.coverage
htmlcov/

# Build / packaging artifacts (only appear if you package this as a library)
dist/
build/
*.egg-info/

# IDE personal settings (yours, not part of the project)
.vscode/
.idea/
*.swp

# OS-level junk
.DS_Store
Thumbs.db
